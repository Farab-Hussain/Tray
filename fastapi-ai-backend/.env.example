# Copy to .env and set your real keys. Never commit .env.

NODE_ENV=development

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Default provider if request payload does not include one: openai | claude
DEFAULT_AI_PROVIDER=openai

# Default model names
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Comma-separated extra CORS origins (production hosts are built into cors_origins.py)
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:8081
# Production example:
# ALLOWED_ORIGINS=https://tray-ecru.vercel.app,https://tray-dashboard-eight.vercel.app

# Optional: restrict /api/admin-ai/insights to backend proxy only
ADMIN_AI_SHARED_SECRET=
