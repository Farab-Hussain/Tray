# Shared monorepo ignore for Vercel git deploys.
# Do NOT ignore `web` — tray-dashboard Root Directory is `web`.
# Do NOT ignore `backend` — tray API Root Directory is `backend`.

# Only ignore the React Native app at repo root (not web/app)
/app
/fastapi-ai-backend
/firebase
/doc
/docs
/tests
/.cursor
/.idea
/.vscode
.git
**/.git
**/node_modules
**/dist
**/.next
**/Pods
**/build
**/DerivedData
**/.gradle
**/.expo
**/*.ipa
**/*.apk
**/*.aab
**/*.keystore
google-services*.json
tray-release.keystore
.env
.env.*
!.env.example
